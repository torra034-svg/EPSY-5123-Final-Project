train_data <- training(data_split)
test_data <- testing(data_split)
# Chunk 8: linear-model
#| label: linear-model
#| message: false
#| warning: false
#| echo: true
lm_spec <- linear_reg() %>%
set_engine("lm") %>%
set_mode("regression")
# Chunk 9: lm-recipe
#| label: lm-recipe
#| message: false
#| warning: false
#| echo: true
lm_recipe <- recipe(
Avg ~ roommate_status + stressful_event,
data = train_data
) %>%
step_dummy(all_nominal_predictors()) %>%
step_normalize(all_predictors())
# Chunk 10: workflow
