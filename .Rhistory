add_model(lm_spec) %>%
add_recipe(lm_recipe)
# Chunk 11: fit-model
#| label: fit-model
#| message: false
#| warning: false
#| echo: true
lm_fit <- fit(lm_workflow, data = train_data)
extract_fit_parsnip(lm_fit) %>% tidy()
# Chunk 12: eval-lm-model-performance
#| label: eval-lm-model-performance
#| message: false
#| warning: false
#| echo: true
# Make predictions
results <- predict(lm_fit, new_data = test_data) %>%
bind_cols(test_data)
# Check metrics
metrics(results, truth = outcome_var, estimate = .pred)
