#| label: fig-stress-time-series
#| fig-cap: "Patrick's Stress Levels in Chronological Order"
#| fig-cap-location: "top"
ggplot(avg_stress_clean, aes(x = clean_date, y = Avg, color = roommate_status)) +
geom_point() +
labs(x = "Timeline",
y = "Average Stress Levels",
color = "Roommate Status",
title = "Patrick's Average Stress Levels (2025-2026)")
# Chunk 6: fig-stress-roommate
#| label: fig-stress-roommate
#| fig-cap: "Unadjusted Stress Levels"
#| fig-cap-location: top
ggplot(avg_stress_clean, aes(x = roommate_status, y = Avg, fill = roommate_status)) +
geom_col() +
labs(x = NULL,
y = "Average Stress Levels Summation",
fill = "Roommate Status",
title = "Summation of Average Stress Levels by Roommate Status") +
theme(axis.text.x = element_blank(),
axis.title.x = element_blank(),
axis.ticks.x = element_blank())
# Chunk 7: data-split
#| label: data-split
#| message: false
#| warning: false
#| echo: true
set.seed(123)
data_split <- initial_split(avg_stress_clean, prop = 0.80)
train_data <- training(data_split)
test_data <- testing(data_split)
# Chunk 8: linear-model
#| label: linear-model
#| message: false
#| warning: false
#| echo: true
lm_spec <- linear_reg() %>%
set_engine("lm") %>%
set_mode("regression")
# Chunk 9: lm-recipe
#| label: lm-recipe
#| message: false
#| warning: false
#| echo: true
lm_recipe <- recipe(
Avg ~ roommate_status + stressful_event,
data = train_data
) %>%
step_dummy(all_nominal_predictors()) %>%
step_normalize(all_predictors())
# Chunk 10: workflow
#| label: workflow
#| message: false
#| warning: false
#| echo: true
lm_workflow <- workflow() %>%
add_model(lm_spec) %>%
add_recipe(lm_recipe)
# Chunk 11: fit-model
